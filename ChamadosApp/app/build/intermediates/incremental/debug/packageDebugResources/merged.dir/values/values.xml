<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background_light">#F8F9FA</color>
    <color name="black">#000000</color>
    <color name="card_white">#FFFFFF</color>
    <color name="cinza_claro">@color/resolve_gray_light</color>
    <color name="cinza_escuro">@color/resolve_gray_dark</color>
    <color name="divider">#E0E0E0</color>
    <color name="fundo_claro">@color/background_light</color>
    <color name="fundo_medio">@color/divider</color>
    <color name="laranja_claro">@color/resolve_orange</color>
    <color name="laranja_escuro">@color/resolve_orange_dark</color>
    <color name="marrom">@color/resolve_orange_dark</color>
    <color name="resolve_black">#131314</color>
    <color name="resolve_gray_dark">#2B353C</color>
    <color name="resolve_gray_light">#545D63</color>
    <color name="resolve_orange">#FC6604</color>
    <color name="resolve_orange_dark">#E54305</color>
    <color name="status_done">#2E7D32</color>
    <color name="status_open">#E54305</color>
    <color name="status_progress">#FC6604</color>
    <color name="text_primary">#131314</color>
    <color name="text_secondary">#545D63</color>
    <color name="white">#FFFFFF</color>
    <style name="ModernButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ModernCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">6dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    <style name="Theme.ResolveTI" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/resolve_orange</item>
        <item name="colorPrimaryVariant">@color/resolve_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/resolve_black</item>
    </style>
</resources>