<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundo_claro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/atend_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/cinza_escuro"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/atend_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cinza_claro"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/atend_descricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fundo_medio"
            android:padding="12dp"
            android:textColor="@color/cinza_escuro"
            android:layout_marginBottom="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/cinza_claro"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrar Solução:"
            android:textStyle="bold"
            android:textColor="@color/cinza_escuro"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/edit_solucao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descreva a solução aplicada..."
            android:inputType="textMultiLine"
            android:lines="4"
            android:gravity="top"
            android:background="@color/fundo_medio"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar Status:"
            android:textStyle="bold"
            android:textColor="@color/cinza_escuro"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinner_status"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/fundo_medio"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_salvar_atendimento"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Salvar Atendimento"
            android:backgroundTint="@color/marrom"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>
